# ── App ──────────────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=troque-isso-em-producao

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/facial_auth

# ── InsightFace ────────────────────────────────────────────────────────────────
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_CTX_ID=-1
SIMILARITY_THRESHOLD=0.40

# ── Liveness ──────────────────────────────────────────────────────────────────
# Opções: "aws" | "silent_face" | "none"
LIVENESS_PROVIDER=none

# AWS Rekognition (necessário se LIVENESS_PROVIDER=aws)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Segurança ─────────────────────────────────────────────────────────────────
# Deixe vazio em dev para desabilitar autenticação por API Key
# Em produção: gere chaves com: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=["sua-chave-aqui","outra-chave"]

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
